<div class="card">

  <div class="card-header">
    Forum
  </div>

  <div class="nav justify-content-end">
    <%= link_to 'Back', forums_path, class: "btn  btn-primary btn-back" %>
    <%= link_to 'Edit', edit_forum_path(@forum), class: "btn btn-primary "%>
  </div>

	  <h1 class="text-center"><%= @forum.titulo %></h1>
    <p class="text-justify"><%= @forum.descricao %></p>
  <div class="nav justify-content-end">
    <%= link_to 'Back', forums_path, class: "btn  btn-primary" %>
    <%= link_to 'Edit', edit_forum_path(@forum), class: "btn btn-primary "%>
  </div>
  <div class="conte-fluid">
    <h1 class="text-center">Comentarios</h1>
    <% @comentarios.each do |comentario| %>
        <p class="text-justify"><%= comentario.comentario %></p>
        <td><%= link_to 'Destroy', comentario, method: :delete, data: { confirm: 'Are you sure?' } %></td>

    <% end %>

  </div>
  <div class="contener-fluid mx-auto">

  </div>
    <div class="contener-fluid">
      <%= render 'comentarios/form', comentario: Comentario.new%>

    </div>

</div>
