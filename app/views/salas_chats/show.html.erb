<div class="card">

  <div class="card-header">Sala de Chat</div>

  <ul class="list-group">
    <li class="list-group-item"><b>Nome:</b><%= @sala_chat.nome %></li>
    <li class="list-group-item"><b>Curso:</b> <%= @sala_chat.curso.nome %></li>
    <li class="list-group-item"><b>Responsável:</b> <%= @sala_chat.usuario_curso.nickname %></li> 
    <li class="list-group-item"><b>Cadastrado em:</b> <%= @sala_chat.created_at.strftime("%d/%m/%Y") %></li>     
  </ul>

  <br>
  <div class="text-center">
    <% if can? :edit, SalaChat %>
      <%= link_to 'Atualizar', edit_sala_chat_path(@sala_chat), class: "btn btn-md btn-primary" %>
    <% end %>
    <%= link_to 'Voltar', salas_chats_path, class: "btn btn-md btn-secondary" %>
  </div>



<div id="mensagens" data-sala-chat-id="<%= @sala_chat.id %>">
  <%= render @sala_chat.mensagens_chats %>
</div>

<%= form_for @mensagem_chat, url: "#" do |f| %>
  <%= hidden_field_tag 'sala_chat_id', @sala_chat.id %>
  <div class="form-group">
    <%= f.label :texto %>
    <%= f.text_area :texto, class: 'form-control' %>
    <small class="text-muted">De 2 a 1000 caracters</small>
  </div>

  <%= f.submit "Enviar", class: 'btn btn-primary btn-lg' %>
<% end %>


</div>