<%= form_with(model: atividade_extra, local: true) do |form| %>
  <% if atividade_extra.errors.any? %>
    <div id="error_explanation" class="alert alert-danger">
      <h2><%= pluralize(atividade_extra.errors.count, "erros") %> impediram essa atividade de ser salva:</h2>

      <ul>
      <% atividade_extra.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
  <%= form.hidden_field :modulo_id %>
  <div class="card-body">

    <div class="form-group row">
      <label for="inputPontuacao" class="col-md-2 offset-md-2 col-form-label">Pontuação*</label>
      <div class="col-sm-2">
        <%= form.number_field :pontuacao, autofocus: true, class: "form-control" %>
      </div>
    </div>

    <div class="form-group row">
      <label for="inputDescricao" class="col-md-2 offset-md-2 col-form-label">Descrição</label>
      <div class="col-md-6">
        <%= form.cktext_area :descricao, autofocus: true, class: "form-control" %>
      </div>
    </div>
    
  </div>

  <div class="card-footer text-muted">
    <%= form.submit "Salvar", class: "btn btn-md btn-primary" %>
    <%= link_to 'Voltar', modulos_path, class: "btn btn-md btn-secondary" %>
  </div>
<% end %>
