<div id=modulo_ordenacao_<%= modulo_ordenacao.id %> class="modulo-item"> 

    <%= link_to modulo_ordenacao.objeto,  {:remote => true, 'data-toggle' =>  "modal", 'data-target' => '#modal-window'} do %>
      <i class = "fa fa-exclamation-circle text-orange"> Atividade Extra</i>
    <% end %>
	<% if can? :edit, AtividadeExtra %>
	<%= link_to '', edit_atividade_extra_path(modulo_ordenacao.objeto), class: "fa fa-edit" %>
	<% end %>
	<% if can? :destroy, AtividadeExtra %>
	<%= link_to '', modulo_ordenacao.objeto, method: :delete, data: { confirm: 'Deseja realmente excluir a Atividade?' }, class: "fa fa-trash" %>
	<% end %>
</div>