<div class="card">

  <div class="card-header">Notas da Turma </div>

<% @modulos.each do |modulo| %>
    <h5 class="p-3 mb-2 bg-info text-white text-center"><b>Módulo:</b> <%= link_to modulo.nome, modulo, class: "text-light" %></h5>
    <% Missao.where(modulo_id: modulo.id).each do |missao| %>
	    <h6 class="p-3 mb-2 bg-secondary text-white text-center">
			<b>Missão (<%= missao.tipo %>):</b> <%= link_to missao.nome, missao, class: "text-light" %></h6>
	    <% if missao.tipo == 'Tarefa' %>
	    	<%= render partial: "tarefas/tarefas_turma", locals: {tarefa: missao} %>
	    <% end %>
	    <% if missao.tipo == 'Quiz' %>
	    	<%= render partial: "quizzes/quizzes_turma", locals: {quiz: missao} %>
		<% end %>
	<% end %>
	<% AtividadeExtra.where(modulo_id: modulo.id).each do |atividade| %>
	<h6 class="p-3 mb-2 bg-secondary text-white text-center">
		<b>Missão (Atividade Extra):</b> <%= link_to atividade.pontuacao, atividade, class: "text-light" %></h6>
			<% if atividade %>
				<%= render partial: "atividade_extras/atividades_extras_turma", locals: {atividade_extra: atividade} %>
			<% end %>
	<% end %>
<% end %>

</div>
