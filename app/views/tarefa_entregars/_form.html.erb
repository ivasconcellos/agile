<div class="card-body">

<%= form_with(model: tarefa_entregar, local: true) do |form| %>
  <% if tarefa_entregar.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(tarefa_entregar.errors.count, "error") %> prohibited this tarefa_entregar from being saved:</h2>

      <ul>
      <% tarefa_entregar.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
  <%= form.hidden_field :tarefa_id %>
  <%= hidden_field_tag 'tarefa_entregar[usuario_curso_id]', @usuario_curso_id %>



  <div class="form-group row">
      <label for="inputTexto" class="col-md-2 offset-md-2 col-form-label">Comentario*</label>
      <div class="col-md-6">
      <%= form.text_area :comentario, class: "form-control" %>
    </div>
  </div>
  <div class="form-group row">
      <label for="inputDescricao" class="col-md-2 offset-md-2 col-form-label">Arquivo*</label>
      <div class="col-md-6">
        <%= form.file_field :arquivo %>
      </div>
    </div>
  </div>


  <div class="text-center">
    <%= form.submit "Salvar", class: "btn btn-md btn-primary" %>
    <%= link_to 'Voltar', conteudos_path, class: "btn btn-md btn-secondary" %>
  </div>
<% end %>
</div>
