<div class="card">

<p id="notice"><%= notice %></p>
<div class="card-header"> Tarefa do: <%= @tarefa_entregar.usuario_curso.usuario.nome %> </div>

<ul class="list-group">
   <li class="list-group-item"><b>Terefa:</b>   <%= @tarefa_entregar.tarefa.conteudo.nome %></li>
   <li class="list-group-item"><b>Comentario:</b> <%= @tarefa_entregar.comentario %></li>
   <li class="list-group-item"><b>Arquivo:</b> <%= link_to image_tag("documento.png", :alt => "documento", size: "50x50"), @tarefa_entregar.arquivo.url, target: 'popup' %></li>
</ul>


<div class="card-footer text-muted">
  <% if can? :edit, Tarefa %>
    <%= link_to 'Atualizar',  edit_tarefa_entregar_path(@tarefa_entregar), class: "btn btn-md btn-primary" %>
  <% end %>
    <%= link_to  'Enviar nota', {controller: 'tarefa_alunos', action: 'new', tarefa_id: @tarefa_entregar.tarefa_id}, class: "btn btn-md btn-danger"  %>

  <%= link_to 'Voltar',tarefa_entregars_path, class: "btn btn-md btn-secondary" %>
</div>

</div>
