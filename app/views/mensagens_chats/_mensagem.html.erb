<div class="card">
  <div class="card-block">
    <div class="row">
      <div class="col-md-1">
        <%= image_tag mensagem.usuario_curso.avatar.url(:thumb), class: "img-responsive img-thumbnail" %>
      </div>
      <div class="col-md-11">
        <p class="card-text">
          <span class="text-muted"><%= mensagem.usuario_curso.nickname %> as <%= mensagem.created_at.strftime('%H:%M:%S %d %B %Y') %> diz</span><br>
          <%= mensagem.texto %>
        </p>
      </div>
    </div>
  </div>
</div>
